<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net6.0-windows</TargetFramework>
		<Nullable>disable</Nullable>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>disable</ImplicitUsings>

		<!-- Имя EXE -->
		<AssemblyName>HonestFlow</AssemblyName>
		<RootNamespace>HonestFlow</RootNamespace>

		<!-- Для одного EXE -->
		<SelfContained>true</SelfContained>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<PublishSingleFile>true</PublishSingleFile>
		<PublishTrimmed>false</PublishTrimmed>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		<ApplicationManifest>app.manifest</ApplicationManifest>

		<!-- Версии и информация -->
		<AssemblyVersion>2.0.0.0</AssemblyVersion>
		<FileVersion>2.0.0.0</FileVersion>
		<Version>2.0.0.0</Version>
		<InformationalVersion>2.0.0.0</InformationalVersion>
		<Authors>Pavel Shadrov</Authors>
		<Company>OOO "Morkovka"</Company>
		<Product>Honest Flow</Product>
		<Description>Установка и настройка компонентов Честного Знака</Description>
		<Copyright>Copyright © Pavel Shadrov 2024-2026</Copyright>
		<ApplicationIcon>Resourses\hf.ico</ApplicationIcon>
	</PropertyGroup>

	<ItemGroup>
	  <Content Include="Resourses\hf.ico" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
		<PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.9" />
	</ItemGroup>

</Project>